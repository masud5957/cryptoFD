# BSC Mainnet Configuration
RPC_URL=https://bsc-dataseed.binance.org/

# USDT BEP-20 Contract Address (BSC Mainnet)
USDT_CONTRACT=0x55d398326f99059fF775485246999027B3197955

# HD Wallet Mnemonic for generating deposit addresses
# IMPORTANT: Use the SAME mnemonic as the main app for address generation
MNEMONIC=your twelve word seed phrase here for hd wallet generation

# Hot Wallet - Used for sending gas and processing withdrawals
# This wallet needs BNB for gas and USDT for withdrawals
HOT_WALLET_PRIVATE_KEY=your_hot_wallet_private_key_without_0x_prefix
HOT_WALLET_ADDRESS=0xYourHotWalletAddress

# Supabase Configuration (use service role key for full access)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
